# Copy to .env and edit. SQLite is fine for local dev; switch to Postgres for prod.
DATABASE_URL=sqlite:///./dev.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/itrequest

JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-too
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

# Public origin for invite/reset links
PUBLIC_BASE_URL=http://localhost:5173

# CORS
CORS_ORIGINS=http://localhost:5173

# SMTP (leave blank in dev — emails go to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_TLS=true

# Bootstrap Global Admin (used by `python -m app.seed`).
# Leave BOOTSTRAP_ADMIN_PASSWORD blank to use the first-run web wizard at
# /admin/login (recommended). Set both to seed an admin non-interactively.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Platform Admin
