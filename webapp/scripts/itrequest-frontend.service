[Unit]
Description=IT Request Platform — Frontend (vite preview)
After=network.target itrequest-backend.service

[Service]
Type=simple
User=__USER__
Group=__USER__
WorkingDirectory=__APP_DIR__/webapp/frontend
Environment="FRONTEND_PORT=5173"
EnvironmentFile=-__APP_DIR__/webapp/runtime.env
ExecStart=/usr/bin/npm run preview -- --host 0.0.0.0 --port ${FRONTEND_PORT}
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
